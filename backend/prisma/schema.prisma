generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://tasktracker_db_xamn_user:XAfaGMKWRhvDtlSS8zyNQadydCd1tfSy@://render.com"
}


model User {
  id        String   @id @default(cuid()) // Changed to cuid() for Postgres
  name      String
  email     String   @unique
  password  String
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid()) // Changed to cuid() for Postgres
  title       String
  description String   @default("")
  completed   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String                        // Removed @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
